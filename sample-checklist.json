      "ItemLabel": "Change Priority With Database Verification",
      "Steps": [
        {
          "StepNumber": 1,
          "Action": "Open {{BaseUrl}}/issues/{{SampleIssueId}}",
          "Verifications": [
            {
              "Text": "Issue detail page loads and shows current priority"
            }
          ]
        },
        {
          "StepNumber": 2,
          "Action": "Change Priority to 'High' and click Save",
          "Verifications": [
            {
              "Text": "A success toast appears and the Priority field shows 'High'"
            }
          ]
        },
        {
          "StepNumber": 3,
          "Action": "Verify the change persisted in the database",
          "Verifications": [
            {
              "Text": "Priority column reads 'High' for the sample issue",
              "VerificationMethod": "sql",
              "Query": "SELECT Priority FROM Issues WHERE Id = 42",
              "ExpectedValue": "High"
            }
          ]
        }
      ],
      "TestData": {
        "BaseUrl": "http://localhost:5000",
        "SampleIssueId": 42
      },
      "E2ETestReference": "IssueEditWorkflowTests.ChangePriority_PersistsToDatabase",
      "Passes": false,
